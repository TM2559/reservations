# Admin WebAuthn (Face ID) – musí být stejné jako VITE_ADMIN_PASSWORD v salon-system/.env
ADMIN_PASSWORD=your-secret-password

# BulkGate SMS (volitelné – pro připomínky a potvrzení)
# BULKGATE_APPLICATION_ID=
# BULKGATE_APPLICATION_TOKEN=
# BULKGATE_SENDER_ID=
# BULKGATE_SENDER_ID_VALUE=

# Gemini API (volitelné – pro Magic Wand v adminu)
# GEMINI_API_KEY=

# Vlastní doména pro Face ID (volitelné) – hostname oddělené čárkou, např. rezervace.skinstudio.cz
# WEBAPP_ORIGIN_HOSTS=

# Resend (volitelné – potvrzovací e-maily u rezervací a dárkových poukazů z Functions)
# RESEND_API_KEY=
# RESEND_FROM="Skin Studio <rezervace@skinstudio.cz>"
# RESEND_REPLY_TO=
# RESEND_ADMIN_TO=rezervace@skinstudio.cz
