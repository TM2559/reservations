rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Galerie Instagram – čtení pro všechny, zápis jen pro přihlášené (admin)
    match /instagram-showcase/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /cosmetics/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
